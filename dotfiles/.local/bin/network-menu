#!/usr/bin/env bash

set -u

notify_info() {
  if command -v notify-send >/dev/null 2>&1; then
    notify-send "Redes" "$1" 2>/dev/null || true
  fi
}

if ! command -v foot >/dev/null 2>&1 || ! command -v impala >/dev/null 2>&1; then
  notify_info "Necesito Foot e Impala"
  exit 1
fi

rfkill unblock wifi 2>/dev/null || true

exec foot \
  --app-id impala-floating \
  --title "Wi-Fi" \
  --override=main.font="JetBrainsMono Nerd Font:size=8.5" \
  --override=main.pad=6x4 \
  --override=colors.alpha=1.0 \
  --window-size-chars=92x28 \
  -e impala
