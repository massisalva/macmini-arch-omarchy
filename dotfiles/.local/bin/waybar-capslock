#!/usr/bin/env bash

set -u

shopt -s nullglob

caps_active=0

for led in /sys/class/leds/input*::capslock/brightness; do
  if [ "$(cat "$led" 2>/dev/null || printf '0')" = "1" ]; then
    caps_active=1
    break
  fi
done

if [ "$caps_active" -eq 1 ]; then
  printf '{"text":"󰌌 A","tooltip":"Mayúsculas activadas","class":"active"}\n'
else
  printf '{"text":"","tooltip":"Mayúsculas desactivadas","class":"inactive"}\n'
fi
