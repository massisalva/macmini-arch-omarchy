#!/usr/bin/env bash

set -euo pipefail

export XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
export XDG_CURRENT_DESKTOP="${XDG_CURRENT_DESKTOP:-Hyprland}"
export XDG_SESSION_TYPE="${XDG_SESSION_TYPE:-wayland}"
export DBUS_SESSION_BUS_ADDRESS="${DBUS_SESSION_BUS_ADDRESS:-unix:path=${XDG_RUNTIME_DIR}/bus}"

if [ -z "${WAYLAND_DISPLAY:-}" ]; then
  if [ -S "$XDG_RUNTIME_DIR/wayland-1" ]; then
    export WAYLAND_DISPLAY="wayland-1"
  else
    WAYLAND_SOCKET="$(find "$XDG_RUNTIME_DIR" -maxdepth 1 -type s -name 'wayland-*' 2>/dev/null | head -n1)"
    if [ -n "$WAYLAND_SOCKET" ]; then
      WAYLAND_DISPLAY="$(basename "$WAYLAND_SOCKET")"
      export WAYLAND_DISPLAY
    fi
  fi
fi

notify_info() {
  if command -v notify-send >/dev/null 2>&1; then
    notify-send -t "${2:-2500}" "Captura" "$1" 2>/dev/null || true
  fi
}

if ! command -v grim >/dev/null 2>&1; then
  notify_info "No encontré grim"
  exit 1
fi

if [ -z "${WAYLAND_DISPLAY:-}" ]; then
  notify_info "No pude encontrar la sesión gráfica"
  exit 1
fi

DIR="$HOME/Imágenes/Capturas"

timestamp="$(date +%Y%m%d-%H%M%S)"
file="${2:-$DIR/captura-$timestamp.png}"
mkdir -p "$(dirname "$file")"

notify_ok() {
  notify_info "Guardada: $1" 2500
}

notify_clip() {
  notify_info "Copiada: $1" 2500
}

notify_cancel() {
  notify_info "Cancelada" 1200
}

focused_geometry() {
  command -v hyprctl >/dev/null 2>&1 || return 1
  hyprctl -j activewindow | python -c '
import json, sys

window = json.load(sys.stdin)
x, y = window.get("at", [0, 0])
w, h = window.get("size", [0, 0])

if w <= 0 or h <= 0:
    sys.exit(1)

print(f"{x},{y} {w}x{h}")
'
}

choose_mode() {
  if ! command -v fuzzel >/dev/null 2>&1; then
    notify_info "No encontré fuzzel"
    exit 1
  fi

  printf "󰍹  Pantalla completa\n󰩭  Seleccionar región\n󰖲  Ventana enfocada\n󰅍  Copiar pantalla completa\n󰅍  Copiar región\nCancelar\n" |
    fuzzel --dmenu --width=34 --lines=6 --prompt="Captura: "
}

mode="${1:-}"

if [ -z "$mode" ]; then
  choice="$(choose_mode)"

  case "$choice" in
    "󰍹  Pantalla completa") mode="full" ;;
    "󰩭  Seleccionar región") mode="region" ;;
    "󰖲  Ventana enfocada") mode="window" ;;
    "󰅍  Copiar pantalla completa") mode="full-copy" ;;
    "󰅍  Copiar región") mode="region-copy" ;;
    *) exit 0 ;;
  esac
fi

case "$mode" in
  full)
    grim "$file"
    notify_ok "$file"
    ;;

  region)
    if ! command -v slurp >/dev/null 2>&1; then
      notify_info "No encontré slurp"
      exit 1
    fi
    geometry="$(slurp || true)"
    [ -n "$geometry" ] || { notify_cancel; exit 0; }
    grim -g "$geometry" "$file"
    notify_ok "$file"
    ;;

  window)
    set +e
    geometry="$(focused_geometry)"
    status=$?
    set -e
    [ "$status" -eq 2 ] && exit 0
    [ -n "$geometry" ] || { notify_info "No pude detectar la ventana enfocada" 2000; exit 1; }
    grim -g "$geometry" "$file"
    notify_ok "$file"
    ;;

  full-copy)
    if ! command -v wl-copy >/dev/null 2>&1; then
      notify_info "No encontré wl-copy"
      exit 1
    fi
    grim - | wl-copy
    notify_clip "Pantalla completa"
    ;;

  region-copy)
    for cmd in slurp wl-copy; do
      if ! command -v "$cmd" >/dev/null 2>&1; then
        notify_info "No encontré $cmd"
        exit 1
      fi
    done
    geometry="$(slurp || true)"
    [ -n "$geometry" ] || { notify_cancel; exit 0; }
    grim -g "$geometry" - | wl-copy
    notify_clip "Región seleccionada"
    ;;

  *)
    notify_info "Modo no reconocido: $mode" 2500
    exit 1
    ;;
esac
