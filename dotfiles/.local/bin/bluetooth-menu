#!/usr/bin/env bash

notify_info() {
  if command -v notify-send >/dev/null 2>&1; then
    notify-send "Bluetooth" "$1" 2>/dev/null || true
  fi
}

if ! command -v foot >/dev/null 2>&1; then
  notify_info "No encontré foot"
  exit 1
fi

if ! command -v bluetui >/dev/null 2>&1; then
  notify_info "No encontré bluetui"
  exit 1
fi

exec foot \
  --app-id bluetui-floating \
  --title "Bluetooth" \
  --override=main.font="JetBrainsMono Nerd Font:size=8.5" \
  --override=main.pad=6x4 \
  --override=colors.alpha=1.0 \
  --window-size-chars=92x28 \
  -e bluetui
